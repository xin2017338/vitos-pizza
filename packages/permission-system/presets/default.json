{
	"permission": {
		"*": "allow",
		"read": "allow",
		"grep": "allow",
		"find": "allow",
		"ls": "allow",
		"hypa_read": "allow",
		"hypa_grep": "allow",
		"hypa_find": "allow",
		"hypa_ls": "allow",
		"hypa_shell": "ask",
		"hypa_mcp_proxy": "deny",
		"web_search": "ask",
		"web_read": "ask",
		"path": {
			"*": "allow",
			"*.env": "deny",
			"*.env.*": "deny",
			"*.env.example": "allow",
			"~/.ssh/*": "deny"
		},
		"bash": {
			"*": "ask",
			"git status": "allow",
			"git status *": "allow",
			"git diff": "allow",
			"git diff *": "allow",
			"git log": "allow",
			"git log *": "allow",
			"ls": "allow",
			"ls *": "allow",
			"npm test": "allow",
			"npm test *": "allow",
			"npm run typecheck": "allow",
			"npm run lint": "allow",
			"hypa *": "ask",
			"hypa -c *": "ask",
			"rm -rf *": "deny",
			"sudo *": "ask"
		},
		"external_directory": "ask"
	}
}
